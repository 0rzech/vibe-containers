#!/bin/bash

set -euo pipefail

work_dir="$(realpath .)"
dir_name="$(basename "${work_dir}")"
container_name="vibe-${dir_name//[^a-zA-Z0-9.-]/-}-${RANDOM}"
vibe_home="${VIBE_HOME:-${HOME}/.vibe}"

exec podman run \
  --init \
  --tty \
  --interactive \
  --rm \
  --cap-drop all \
  --security-opt no-new-privileges \
  --userns keep-id \
  --workdir "${work_dir}" \
  --volume "${vibe_home}:${vibe_home}:z" \
  --volume "${work_dir}:${work_dir}:z" \
  --env "TERM=${TERM}" \
  --hostname "${container_name}" \
  --name "${container_name}" \
  localhost/vibe-sandbox \
    "${1:-vibe}"
