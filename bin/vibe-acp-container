#!/bin/bash

set -euo pipefail

work_dir="${PWD}"
name="vibe-acp-$(basename "${work_dir}")-${RANDOM}"
vibe_home="${VIBE_HOME:-${HOME}/.vibe}"

exec podman run \
  --interactive \
  --rm \
  --cap-drop all \
  --security-opt no-new-privileges \
  --userns keep-id \
  --workdir "${work_dir}" \
  --volume "${vibe_home}:${vibe_home}:z" \
  --volume "${work_dir}:${work_dir}:z" \
  --hostname "${name}" \
  --name "${name}" \
  localhost/vibe-sandbox \
    "${1:-vibe-acp}"
