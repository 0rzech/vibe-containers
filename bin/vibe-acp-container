#!/bin/bash

set -euo pipefail

work_dir="${PWD}"
name="vibe-acp-$(basename ${work_dir})-${RANDOM}"

exec podman run \
  --interactive \
  --rm \
  --cap-drop all \
  --security-opt no-new-privileges \
  --userns keep-id \
  --workdir "${work_dir}" \
  --mount "type=bind,src=${VIBE_HOME},dst=${VIBE_HOME},relabel=shared" \
  --mount "type=bind,src=${work_dir},dst=${work_dir},relabel=shared" \
  --hostname "${name}" \
  --name "${name}" \
  localhost/vibe-sandbox \
    vibe-acp
